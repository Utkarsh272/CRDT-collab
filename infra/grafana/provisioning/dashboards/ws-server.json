{
  "title": "CRDT Collab — WS Server",
  "uid": "crdt-ws",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(ws_active_connections)",
          "legendFormat": "Connections"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] } } }
    },
    {
      "id": 2,
      "title": "Active Rooms (Documents in Memory)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "ws_active_rooms", "legendFormat": "Rooms" }]
    },
    {
      "id": 3,
      "title": "Messages Received / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(ws_messages_received_total[1m])",
          "legendFormat": "msg/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "Connections by Document",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "ws_active_connections",
          "legendFormat": "{{doc_id}}"
        }
      ]
    }
  ]
}
